{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "chat.mumo/mcp",
  "description": "Multi-model responses + cross-model reactions. Want more rounds? Context carries automatically. Stop when you have what you need.",
  "version": "0.1.1",
  "repository": {
    "url": "https://github.com/mumo-chat/mumo-mcp",
    "source": "github"
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mumo.chat/api/mcp",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {MUMO_API_KEY}",
          "is_secret": true
        }
      ]
    }
  ]
}
